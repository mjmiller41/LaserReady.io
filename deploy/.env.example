# Copy to deploy/.env on the box. Git-ignored; never commit the real one.
# MailerLite embedded-form wiring (Phase 0b). Leave empty to ship with capture disabled.
# Account id + form ids come from MailerLite -> Forms -> Embedded form (the numeric ids
# in the form action URL). Two separate forms = the "tagged by source" requirement.
VITE_ML_ACCOUNT=
VITE_ML_FORM_GUARANTEE=
VITE_ML_FORM_EARLY=
